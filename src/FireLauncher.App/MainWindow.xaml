<Window x:Class="FireLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fire Launcher"
        Width="1380"
        Height="860"
        MinWidth="1280"
        MinHeight="820"
        MaxWidth="1600"
        MaxHeight="1020"
        WindowStartupLocation="CenterScreen"
        Background="#081016"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BlurEffect x:Key="BackgroundBlur" Radius="16" />
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="34" ShadowDepth="0" Opacity="0.24" Color="#000000" />

        <SolidColorBrush x:Key="AccentBrush" Color="#97F260" />
        <SolidColorBrush x:Key="AccentDeepBrush" Color="#78D14E" />
        <SolidColorBrush x:Key="PanelBrush" Color="#E1081118" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#E60B151D" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#315067" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#4C7F59" />
        <SolidColorBrush x:Key="FieldBrush" Color="#FF0F1821" />

        <Style x:Key="SurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="26" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF5FBF8" />
            <Setter Property="FontSize" Value="27" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0ECE6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D2DBD6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#22131B22" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="DataValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF3FAF6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="#FFF5FBF8" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="#FFF5FBF8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFF4FBF7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="{StaticResource FieldBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center" />
                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Width="11"
                                  Height="8"
                                  Stroke="#FF0B120E"
                                  StrokeThickness="2.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 1 4 L 4 7 L 10 1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed" />
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#5C7D96" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ClickMode" Value="Press" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid>
                                <ContentPresenter Margin="14,0,42,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Path Width="10"
                                      Height="6"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,16,0"
                                      VerticalAlignment="Center"
                                      Stretch="Fill"
                                      Fill="#FFEAF7EE"
                                      Data="M 0 0 L 5 6 L 10 0 Z" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#4F7290" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFF4FBF7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="6,4"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2B223240" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A36583D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF5FBF8" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Style="{StaticResource ComboBoxToggleButtonStyle}">
                                <ContentPresenter Margin="14,0,42,0"
                                                  TextElement.Foreground="#FFF5FBF8"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   Focusable="False"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="320"
                                        CornerRadius="16"
                                        Background="#F0101821"
                                        BorderBrush="#476A83"
                                        BorderThickness="1"
                                        Effect="{StaticResource PanelShadow}">
                                    <ScrollViewer Margin="6"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FF0F1B13" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentDeepBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF2FAF4" />
            <Setter Property="Background" Value="#180E1620" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,11" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#547898" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#FFE5F1EA" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="18,10"
                                CornerRadius="14"
                                Background="#140E1520"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2E172522" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#5C7D96" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0"
                                      Margin="0,2,0,0"
                                      HorizontalAlignment="Left"
                                      Background="Transparent"
                                      ClipToBounds="False"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1" />

                            <Border Grid.Row="2"
                                    Background="Transparent">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ForkFamilyListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#140E1620" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ForkFamilyListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="16"
                                CornerRadius="16"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E20303B" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2333473F" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid>
            <Image Source="/Assets/fire-launcher-hero.png"
                   Stretch="UniformToFill"
                   Opacity="0.92"
                   Effect="{StaticResource BackgroundBlur}" />
            <Rectangle Fill="#580A1016" />
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.22,0.18"
                                         GradientOrigin="0.22,0.18"
                                         RadiusX="1.08"
                                         RadiusY="1.08">
                        <GradientStop Color="#50305440" Offset="0" />
                        <GradientStop Color="#B20B131B" Offset="0.62" />
                        <GradientStop Color="#ED070C11" Offset="1" />
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <Grid Margin="28">
            <Border Width="1260"
                    Height="760"
                    Background="#D40A131B"
                    BorderBrush="#31536A"
                    BorderThickness="1"
                    CornerRadius="30"
                    Padding="26"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource PanelShadow}">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="210" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                        Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.02*" MinWidth="360" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="0.92*" MinWidth="500" MaxWidth="570" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                MaxWidth="720"
                                VerticalAlignment="Center"
                                Margin="0,6,0,6">
                        <DockPanel LastChildFill="True">
                            <Border Width="88"
                                    Height="88"
                                    Padding="10"
                                    CornerRadius="20"
                                    Background="#D70F1720"
                                    BorderBrush="#406179"
                                    BorderThickness="1"
                                    DockPanel.Dock="Left">
                                <Image Source="/Assets/fire-logo.png"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            </Border>

                            <StackPanel Margin="20,4,0,0">
                                <TextBlock Text="Fire Launcher"
                                           Foreground="#FFFFFFFF"
                                           FontSize="52"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="HeroSelectionText"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="17"
                                           Margin="0,6,0,0"
                                           Text="Pick a fork family and version from the launch deck." />
                            </StackPanel>
                        </DockPanel>

                        <Border Style="{StaticResource SurfaceBorderStyle}"
                                Padding="22"
                                Margin="0,24,0,0"
                                Effect="{StaticResource PanelShadow}">
                            <StackPanel>
                                <TextBlock x:Name="HeroProfileText"
                                           Foreground="#FFF7FBF8"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Text="Profile: Default" />
                                <TextBlock x:Name="DetectedForksText"
                                           Foreground="#FFC6F4D2"
                                           FontSize="14"
                                           Margin="0,12,0,0"
                                           Text="Detected families appear here." />
                                <TextBlock x:Name="ProfileDbSummaryText"
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Style="{StaticResource SurfaceBorderStyle}"
                            Padding="24"
                            Background="{StaticResource PanelAltBrush}"
                            Effect="{StaticResource PanelShadow}">
                        <TabControl Style="{StaticResource PanelTabControlStyle}"
                                    Margin="0,4,8,0">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem" BasedOn="{StaticResource PillTabItemStyle}" />
                            </TabControl.ItemContainerStyle>

                            <TabItem Header="Settings">
                                <Grid Margin="10,10,10,2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Settings" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="Manage folders and the Legacy-DB source Fire Launcher installs from."
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Margin="0,22,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Profiles folder" />
                                        <DockPanel>
                                            <Button x:Name="BrowseProfilesButton"
                                                    Content="Browse"
                                                    DockPanel.Dock="Right"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Click="BrowseFolder_Click"
                                                    Margin="12,0,0,0"
                                                    MinWidth="106" />
                                            <TextBox x:Name="ProfilePathTextBox"
                                                     Style="{StaticResource TextBoxStyle}" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2"
                                                Margin="0,18,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Fork downloads folder" />
                                        <DockPanel>
                                            <Button x:Name="BrowseDownloadsButton"
                                                    Content="Browse"
                                                    DockPanel.Dock="Right"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Click="BrowseDownloadsFolder_Click"
                                                    Margin="12,0,0,0"
                                                    MinWidth="106" />
                                            <TextBox x:Name="DownloadsPathTextBox"
                                                     Style="{StaticResource TextBoxStyle}" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3"
                                                Margin="0,18,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Legacy-DB GitHub repo" />
                                        <TextBox x:Name="CatalogRepositoryTextBox"
                                                 Style="{StaticResource TextBoxStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4"
                                                Margin="0,16,0,0">
                                        <CheckBox x:Name="DiscordPresenceCheckBox"
                                                  Style="{StaticResource ToggleCheckBoxStyle}"
                                                  Content="Enable Discord rich presence" />
                                        <TextBlock Style="{StaticResource HintTextStyle}"
                                                   Margin="0,10,0,0"
                                                   Text="Save &amp; Sync refreshes the catalog and package manifests from Legacy-DB." />
                                    </StackPanel>

                                    <TextBlock x:Name="SettingsStatusText"
                                               Grid.Row="5"
                                               Style="{StaticResource HintTextStyle}"
                                               Margin="0,16,0,0"
                                               VerticalAlignment="Top"
                                               Text="Ready." />

                                    <Grid Grid.Row="6"
                                          Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="170" />
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="OpenProfilesButton"
                                                Grid.Column="0"
                                                Content="Profiles Folder"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Click="OpenProfiles_Click"
                                                MinWidth="142" />
                                        <Button x:Name="OpenDownloadsButton"
                                                Grid.Column="2"
                                                Content="Downloads Folder"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Click="OpenDownloads_Click"
                                                MinWidth="152" />
                                        <Button x:Name="SaveSettingsButton"
                                                Grid.Column="4"
                                                Content="Save &amp; Sync"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Click="SaveSettings_Click"
                                                MinWidth="170" />
                                    </Grid>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Profiles">
                                <Grid Margin="10,10,10,2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Profiles" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="Choose which fork families appear in the launcher."
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,8,0,16" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Selected profile" />
                                        <ComboBox x:Name="ProfileComboBox"
                                                  Style="{StaticResource ComboBoxStyle}"
                                                  SelectionChanged="ProfileComboBox_SelectionChanged" />
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.96*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="1.04*" />
                                        </Grid.ColumnDefinitions>

                                        <ListBox x:Name="ForkFamilyListBox"
                                                 Grid.Column="0"
                                                 Style="{StaticResource ForkFamilyListBoxStyle}"
                                                 ItemContainerStyle="{StaticResource ForkFamilyListItemStyle}"
                                                 SelectionChanged="ForkFamilyListBox_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel LastChildFill="True">
                                                        <CheckBox IsChecked="{Binding ShowInLauncher}"
                                                                  Style="{StaticResource ToggleCheckBoxStyle}"
                                                                  Checked="ForkVisibilityCheckBox_Changed"
                                                                  Unchecked="ForkVisibilityCheckBox_Changed"
                                                                  VerticalAlignment="Top"
                                                                  Margin="0,2,14,0"
                                                                  DockPanel.Dock="Left" />
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding FamilyName}"
                                                                       Foreground="#FFF5FBF8"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       Style="{StaticResource HintTextStyle}"
                                                                       Margin="0,6,0,0" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Border Grid.Column="2"
                                                Style="{StaticResource SurfaceBorderStyle}"
                                                Padding="18">
                                            <StackPanel>
                                                <TextBlock x:Name="ProfileForkTitleText"
                                                           Foreground="#FFF7FBF8"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Text="Fork details" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0,18,0,4"
                                                           Text="Installed status" />
                                                <TextBlock x:Name="ProfileForkInstalledText"
                                                           Style="{StaticResource DataValueStyle}" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0,14,0,4"
                                                           Text="Versions" />
                                                <TextBlock x:Name="ProfileForkVersionsText"
                                                           Style="{StaticResource DataValueStyle}" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0,14,0,4"
                                                           Text="Multiplayer" />
                                                <TextBlock x:Name="ProfileForkMultiplayerText"
                                                           Style="{StaticResource DataValueStyle}" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0,14,0,4"
                                                           Text="Launch arguments" />
                                                <TextBlock x:Name="ProfileForkArgumentsText"
                                                           Style="{StaticResource DataValueStyle}" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0,14,0,4"
                                                           Text="Notes" />
                                                <TextBlock x:Name="ProfileForkNotesText"
                                                           Style="{StaticResource DataValueStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource SurfaceBorderStyle}"
                        Padding="20"
                        Background="{StaticResource PanelAltBrush}"
                        Effect="{StaticResource PanelShadow}">
                    <StackPanel>
                        <TextBlock x:Name="BarProfileText"
                                   Foreground="#FFF7FBF8"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="Launch" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="0.82*" />
                                <ColumnDefinition Width="1.08*" />
                                <ColumnDefinition Width="1.02*" />
                                <ColumnDefinition Width="1.08*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,14,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Fork family" />
                                <ComboBox x:Name="ForkFamilyComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          DisplayMemberPath="FamilyName"
                                          TextSearch.TextPath="FamilyName"
                                          SelectionChanged="ForkFamilyComboBox_SelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,14,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Version" />
                                <ComboBox x:Name="VersionComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          DisplayMemberPath="VersionLabel"
                                          TextSearch.TextPath="VersionLabel"
                                          SelectionChanged="VersionComboBox_SelectionChanged" />
                            </StackPanel>

                            <StackPanel x:Name="UsernameFieldPanel"
                                        Grid.Column="2"
                                        Margin="0,0,14,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Username" />
                                <TextBox x:Name="UsernameTextBox"
                                         Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>

                            <StackPanel x:Name="OnlineModePanel"
                                        Grid.Column="3"
                                        Margin="0,0,14,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Connection" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource FieldBrush}"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Height="48"
                                            Padding="12,0">
                                        <CheckBox x:Name="OnlineModeCheckBox"
                                                  Style="{StaticResource ToggleCheckBoxStyle}"
                                                  Content="Online mode"
                                                  VerticalAlignment="Center"
                                                  Checked="OnlineModeCheckBox_Changed"
                                                  Unchecked="OnlineModeCheckBox_Changed" />
                                    </Border>
                                    <Button x:Name="ConnectionSettingsButton"
                                            Grid.Column="2"
                                            Content="Server"
                                            Style="{StaticResource GhostButtonStyle}"
                                            MinWidth="90"
                                            Height="48"
                                            Click="ConnectionSettingsButton_Click" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Margin="0,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Actions" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="DownloadButton"
                                            Grid.Column="0"
                                            Content="Download"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Click="DownloadSelectedFork_Click"
                                            Height="46" />
                                    <Button x:Name="LaunchButton"
                                            Grid.Column="2"
                                            Content="Launch"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="LaunchButton_Click"
                                            Height="46" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="InstallOverlay"
              Visibility="Collapsed"
              Background="#86070E15">
            <Border Width="460"
                    Padding="28"
                    Background="#EE09131B"
                    BorderBrush="#3D6076"
                    BorderThickness="1"
                    CornerRadius="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock x:Name="InstallOverlayTitleText"
                               Foreground="#FFF7FBF8"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Text="Installing fork" />
                    <TextBlock x:Name="InstallOverlayMessageText"
                               Margin="0,12,0,0"
                               Style="{StaticResource HintTextStyle}"
                               Text="Preparing download..." />
                    <ProgressBar x:Name="InstallOverlayProgressBar"
                                 Style="{StaticResource ProgressBarStyle}"
                                 Margin="0,22,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0" />
                    <DockPanel Margin="0,12,0,0">
                        <TextBlock x:Name="InstallOverlayProgressText"
                                   DockPanel.Dock="Right"
                                   Foreground="#FFE5F0E8"
                                   FontSize="13.5"
                                   FontWeight="SemiBold"
                                   Text="0%" />
                        <TextBlock Foreground="#AFC6D2C9"
                                   FontSize="13"
                                   Text="Fire Launcher is downloading and setting up the selected fork." />
                    </DockPanel>
                    <Grid Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CancelInstallButton"
                                Grid.Column="1"
                                Content="Cancel"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="CancelInstallButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ConnectionOverlay"
              Visibility="Collapsed"
              Background="#86070E15">
            <Border Width="430"
                    Padding="28"
                    Background="#EE09131B"
                    BorderBrush="#3D6076"
                    BorderThickness="1"
                    CornerRadius="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock Text="Connection Settings"
                               Foreground="#FFF7FBF8"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ConnectionOverlayHintText"
                               Margin="0,12,0,0"
                               Style="{StaticResource HintTextStyle}"
                               Text="Enter the server address and port for online mode." />
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Server IP" />
                        <TextBox x:Name="ServerIpTextBox"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Port" />
                        <TextBox x:Name="PortTextBox"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <Grid Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Cancel"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="CancelConnectionSettings_Click"
                                Margin="0,0,10,0" />
                        <Button Grid.Column="1"
                                Content="Save"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveConnectionSettings_Click"
                                Margin="10,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
