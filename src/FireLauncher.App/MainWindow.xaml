<Window x:Class="FireLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fire Launcher"
        Width="1220"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#120E10"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BlurEffect x:Key="BackgroundBlur" Radius="22" />
        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="38"
                          ShadowDepth="0"
                          Opacity="0.38"
                          Color="#000000" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF20311A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF11210F" />
            <Setter Property="FontSize" Value="23" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Foreground" Value="#FF1A2813" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Background" Value="#CFFFFFFF" />
            <Setter Property="BorderBrush" Value="#6BFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Background" Value="#CFFFFFFF" />
            <Setter Property="BorderBrush" Value="#6BFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FF132010" />
            <Setter Property="Background" Value="#FFB7FF7A" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FF132010" />
            <Setter Property="Background" Value="#42FFFFFF" />
            <Setter Property="BorderBrush" Value="#5CFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CC20311A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DataValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF0F2310" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ForkListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#26000000" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Foreground" Value="#FF10220E" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="0,0,0,8"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#2AFFFFFF"
                                BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#8CB7FF7A" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#B6F2FFD7" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FFF0FBF0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,10,0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="14"
                                Background="#20000000"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#88B7FF7A" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#B4E8FFCC" />
                                <Setter Property="Foreground" Value="#FF10220E" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#30FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid>
            <Image Source="/Assets/fire-launcher-hero.png"
                   Stretch="UniformToFill"
                   Opacity="0.96"
                   Effect="{StaticResource BackgroundBlur}" />

            <Rectangle Fill="#1A050807" />

            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#B1061208" Offset="0" />
                        <GradientStop Color="#3D2D5C24" Offset="0.48" />
                        <GradientStop Color="#AA170C12" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <Grid Margin="42">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.03*" />
                <ColumnDefinition Width="1.08*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,42,12">
                <Border Background="#2EFFFFFF"
                        BorderBrush="#42FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="12,6"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,18">
                    <TextBlock Text="Open-source Windows shell for Legacy Console forks"
                               Foreground="#FFF4FFF4"
                               FontSize="13" />
                </Border>

                <TextBlock Text="Fire Launcher"
                           Foreground="#FFFFFFFF"
                           FontSize="60"
                           FontWeight="Bold" />

                <TextBlock Text="Local profile folders, real fork records, and direct executable launching for community builds."
                           Foreground="#E6F4FFF2"
                           FontSize="18"
                           TextWrapping="Wrap"
                           MaxWidth="560"
                           Margin="0,12,0,18" />

                <Border Background="#18000000"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18"
                        MaxWidth="510">
                    <StackPanel>
                        <TextBlock Text="Detected local forks are copied into app data automatically when Fire Launcher finds them in Downloads."
                                   Foreground="#FFF7FFF8"
                                   FontSize="15"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="DetectedForksText"
                                   Foreground="#FFA7FFC9"
                                   FontSize="13"
                                   Margin="0,10,0,0"
                                   Text="Detected forks appear here." />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1"
                    MaxWidth="520"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    CornerRadius="28"
                    Padding="18"
                    Background="#46F7F8F2"
                    BorderBrush="#5AFFFFFF"
                    BorderThickness="1"
                    Effect="{StaticResource PanelShadow}">
                <TabControl Background="Transparent"
                            BorderThickness="0">
                    <TabItem Header="Launcher">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <DockPanel Margin="0,0,0,18">
                                    <Image Source="/Assets/fire-logo.png"
                                           Width="82"
                                           Height="82"
                                           Stretch="Uniform"
                                           Margin="0,0,16,0"
                                           DockPanel.Dock="Left"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Launch"
                                                   Foreground="#FF11210F"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Choose a fork and launch the local build."
                                                   Foreground="#CC10200F"
                                                   FontSize="24"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DockPanel>

                                <StackPanel x:Name="UsernameFieldPanel">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Username" />
                                    <TextBox x:Name="UsernameTextBox"
                                             Style="{StaticResource TextBoxStyle}" />
                                </StackPanel>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Fork" />
                                <ComboBox x:Name="ForkComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ForkComboBox_SelectionChanged" />

                                <StackPanel x:Name="ServerIpFieldPanel">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Server IP" />
                                    <TextBox x:Name="ServerIpTextBox"
                                             Style="{StaticResource TextBoxStyle}" />
                                </StackPanel>

                                <StackPanel x:Name="PortFieldPanel">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Port" />
                                    <TextBox x:Name="PortTextBox"
                                             Style="{StaticResource TextBoxStyle}" />
                                </StackPanel>

                                <TextBlock x:Name="LaunchArgsHintText"
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,-8,0,16" />

                                <Border Background="#20000000"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="14"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Current profile"
                                                   Foreground="#FF183115"
                                                   FontSize="12" />
                                        <TextBlock x:Name="SelectedProfileSummaryText"
                                                   Foreground="#FF10230E"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Current fork"
                                                   Foreground="#FF183115"
                                                   FontSize="12"
                                                   Margin="0,12,0,0" />
                                        <TextBlock x:Name="SelectedForkSummaryText"
                                                   Foreground="#FF10230E"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="ForkCapabilitySummaryText"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,6,0,0" />
                                        <TextBlock x:Name="ProfileDatabasePathText"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <DockPanel Grid.Row="2" LastChildFill="False">
                                <Button Content="Open Profiles Folder"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Click="OpenProfiles_Click"
                                        DockPanel.Dock="Left" />
                                <Button Content="Launch"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="LaunchButton_Click"
                                        DockPanel.Dock="Right"
                                        Margin="12,0,0,0" />
                            </DockPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Settings">
                        <StackPanel Margin="12">
                            <TextBlock Text="Settings"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Choose where profile folders live and set the Discord application ID used for rich presence."
                                       Foreground="#CC10200F"
                                       FontSize="14"
                                       Margin="0,0,0,22" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Profiles folder" />
                            <DockPanel Margin="0,0,0,18">
                                <Button Content="Browse"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Click="BrowseFolder_Click"
                                        DockPanel.Dock="Right"
                                        Margin="12,0,0,0" />
                                <TextBox x:Name="ProfilePathTextBox"
                                         Style="{StaticResource TextBoxStyle}"
                                         Margin="0" />
                            </DockPanel>

                            <CheckBox x:Name="DiscordPresenceCheckBox"
                                      Content="Enable Discord rich presence"
                                      Foreground="#FF162312"
                                      IsChecked="True"
                                      Margin="0,0,0,14" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Discord application ID" />
                            <TextBox x:Name="DiscordApplicationIdTextBox"
                                     Style="{StaticResource TextBoxStyle}" />

                            <TextBlock Style="{StaticResource HintTextStyle}"
                                       Text="Presence is enabled by default. Add your Discord application ID here when you are ready to wire it up." />

                            <DockPanel Margin="0,20,0,0" LastChildFill="False">
                                <Button Content="Open Profiles Folder"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Click="OpenProfiles_Click"
                                        DockPanel.Dock="Left" />
                                <Button Content="Save Settings"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="SaveSettings_Click"
                                        DockPanel.Dock="Right"
                                        Margin="12,0,0,0" />
                            </DockPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Profiles">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Profiles"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Each profile folder has its own fork database. Fire Launcher refreshes fork records from known local installs."
                                           Foreground="#CC10200F"
                                           FontSize="14"
                                           Margin="0,0,0,18" />

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Selected profile" />
                                <ComboBox x:Name="ProfileComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          SelectionChanged="ProfileComboBox_SelectionChanged" />

                                <TextBlock x:Name="ProfileDbSummaryText"
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,0,0,14" />

                                <DockPanel Margin="0,0,0,18" LastChildFill="False">
                                    <Button Content="Refresh Forks"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Click="RefreshForks_Click"
                                            DockPanel.Dock="Left" />
                                    <Button Content="Open Selected Fork Folder"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Click="OpenForkFolder_Click"
                                            DockPanel.Dock="Right"
                                            Margin="12,0,0,0" />
                                </DockPanel>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.95*" />
                                    <ColumnDefinition Width="1.1*" />
                                </Grid.ColumnDefinitions>

                                <ListBox x:Name="ForkListBox"
                                         Grid.Column="0"
                                         Style="{StaticResource ForkListBoxStyle}"
                                         SelectionChanged="ForkListBox_SelectionChanged"
                                         DisplayMemberPath="DisplayName" />

                                <Border Grid.Column="1"
                                        Margin="16,0,0,0"
                                        Background="#20000000"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock x:Name="ForkDetailsTitleText"
                                                   Foreground="#FF10230E"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Text="Fork details" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0,16,0,4"
                                                   Text="Install status" />
                                        <TextBlock x:Name="ForkInstallStatusText"
                                                   Style="{StaticResource DataValueStyle}" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0,12,0,4"
                                                   Text="Multiplayer" />
                                        <TextBlock x:Name="ForkMultiplayerText"
                                                   Style="{StaticResource DataValueStyle}" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0,12,0,4"
                                                   Text="Launch arguments" />
                                        <TextBlock x:Name="ForkArgumentsText"
                                                   Style="{StaticResource DataValueStyle}" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0,12,0,4"
                                                   Text="Executable path" />
                                        <TextBlock x:Name="ForkExecutablePathText"
                                                   Style="{StaticResource DataValueStyle}" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0,12,0,4"
                                                   Text="Install folder" />
                                        <TextBlock x:Name="ForkInstallPathText"
                                                   Style="{StaticResource DataValueStyle}" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0,12,0,4"
                                                   Text="Notes" />
                                        <TextBlock x:Name="ForkNotesText"
                                                   Style="{StaticResource DataValueStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
